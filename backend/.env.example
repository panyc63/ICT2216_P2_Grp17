PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=mediflow_db

# Stripe (test mode). STRIPE_SECRET_KEY is REQUIRED — the backend will not start
# without it. Get it from Stripe Dashboard -> Developers -> API keys (test mode).
STRIPE_SECRET_KEY=sk_test_xxx
# Printed by `stripe listen` (starts with whsec_). Needed to verify webhooks.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Where Stripe Checkout returns the patient (optional; defaults to http://localhost:5173)
# FRONTEND_URL=http://localhost:5173

# Only needed if your Realtime Database is in a non-default region
# FIREBASE_DB_URL=https://YOUR-PROJECT-default-rtdb.asia-southeast1.firebasedatabase.app
