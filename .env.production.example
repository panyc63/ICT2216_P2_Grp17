# ============================================================================
# MediFlow production environment (single-VM docker-compose).
# Copy to ".env.production" and fill in. DO NOT commit the real file.
#   cp .env.production.example .env.production
# ============================================================================

# --- Public hostname & HTTPS ---
# DNS A-record for DOMAIN must point at this VM's public IP.
DOMAIN=mediflow.example.com
ACME_EMAIL=you@example.com

# --- Database (root user; password is also the MySQL container root password) ---
DB_USER=root
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=mediflow_db
# DB_HOST is injected as "db" by docker-compose.prod.yml.

# --- App URLs (single origin behind Caddy) ---
FRONTEND_URL=https://mediflow.example.com
BACKEND_PUBLIC_URL=https://mediflow.example.com
CORS_ORIGINS=https://mediflow.example.com

# --- REQUIRED secrets: the backend refuses to start in production if any are missing. ---
# Generate each value with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_random_bytes
CSRF_SECRET=CHANGE_ME_at_least_32_random_bytes
DATA_ENCRYPTION_KEY=CHANGE_ME_at_least_32_random_bytes
MC_SIGNING_KEY=CHANGE_ME_at_least_32_random_bytes

# --- Stripe (optional): webhook returns 503 until set ---
STRIPE_WEBHOOK_SECRET=whsec_change_me

# --- Malware scanning (ClamAV) ---
# The "clamav" service in docker-compose.prod.yml runs clamd; the backend reaches it at
# clamav:3310. When CLAMD_HOST is empty the backend falls back to an EICAR-only stub (no real
# AV). Leave these as-is to use the bundled clamav service.
CLAMD_HOST=clamav
CLAMD_PORT=3310

# --- MFA (staff email OTP) ---
# To ENABLE staff MFA you need BOTH:
#   1) MFA_REQUIRED_ROLES=Doctor,Nurse,Pharmacist,Admin   (the roles that must do OTP)
#   2) a real RESEND_API_KEY  — without an email transporter the OTP is generated but never
#      delivered, so staff would be locked out of login.
#   NOTE: Resend's free tier only delivers to your account's own verified address. For a demo,
#   set a staff seed account's email to that verified address (or verify a domain in Resend).
# To DISABLE for a no-email demo, keep MFA_REQUIRED_ROLES=disabled.
# (Leaving MFA_REQUIRED_ROLES EMPTY in production enables staff MFA by default.)
RESEND_API_KEY=
MFA_REQUIRED_ROLES=disabled
