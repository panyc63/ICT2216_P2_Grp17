# ============================================================================
# MediFlow production environment (single-VM docker-compose).
# Copy to ".env.production" and fill in. DO NOT commit the real file.
#   cp .env.production.example .env.production
# ============================================================================

# --- Public hostname & HTTPS ---
# DNS A-record for DOMAIN must point at this VM's public IP.
DOMAIN=mediflow.example.com
ACME_EMAIL=you@example.com

# --- Database ---
# DB_PASSWORD is also the MySQL container root password (used by backups/migrations).
# Phase 1 of DB account isolation: run ops/db/create-app-users.sh to create a DML-only
# 'mediflow_app' user and a DDL 'mediflow_ddl' migration user (app stays on root until you
# flip it). Phase 2 (maintenance window): set DB_USER=mediflow_app + DB_PASSWORD=<app pw>.
DB_USER=root
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=mediflow_db
# DB_HOST is injected as "db" by docker-compose.prod.yml.
# Least-privilege user passwords (consumed by ops/db/create-app-users.sh; keep out of git):
DB_APP_PASSWORD=CHANGE_ME_app_dml_password
DB_DDL_PASSWORD=CHANGE_ME_ddl_migration_password

# --- App URLs (single origin behind Caddy) ---
FRONTEND_URL=https://mediflow.example.com
BACKEND_PUBLIC_URL=https://mediflow.example.com
CORS_ORIGINS=https://mediflow.example.com

# --- REQUIRED secrets: the backend refuses to start in production if any are missing. ---
# Generate each value with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_random_bytes
CSRF_SECRET=CHANGE_ME_at_least_32_random_bytes
DATA_ENCRYPTION_KEY=CHANGE_ME_at_least_32_random_bytes
MC_SIGNING_KEY=CHANGE_ME_at_least_32_random_bytes

# --- Stripe (optional): webhook returns 503 until set ---
STRIPE_WEBHOOK_SECRET=whsec_change_me

# --- Malware scanning (ClamAV) ---
# The "clamav" service in docker-compose.prod.yml runs clamd; the backend reaches it at
# clamav:3310. When CLAMD_HOST is empty the backend falls back to an EICAR-only stub (no real
# AV). Leave these as-is to use the bundled clamav service.
CLAMD_HOST=clamav
CLAMD_PORT=3310

# --- WebRTC video (TURN) ---
# Video works P2P with public STUN and needs NO inbound ports on this server. For the
# minority of hard-NAT cases, add a MANAGED TURN relay (e.g. Cloudflare/Metered) hosted
# off-box — set its URL(s) + static credentials below. Leave blank for STUN-only.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# --- Email delivery (verification links + staff MFA OTP) ---
# Delivery is provider-agnostic SMTP. Precedence: SMTP_HOST > RESEND_API_KEY > (demo mode).
#
# RECOMMENDED — Brevo (Sendinblue): free 300 emails/day, delivers to ANY recipient, no domain
# needed. Setup:
#   1) Sign up at https://www.brevo.com and confirm your account.
#   2) Senders & IP > Senders: add + verify a single sender email you own (e.g. your Gmail).
#      That verified address MUST be the one in MAIL_FROM below.
#   3) SMTP & API > SMTP: copy the login + generate an "SMTP key" (this is SMTP_PASS, not your
#      account password).
# Then fill in:
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="MediFlow <favianleong@gmail.com>"
#
# ALTERNATIVE — Resend: leave SMTP_HOST empty and set RESEND_API_KEY. NOTE: Resend's free tier
# only delivers to your own verified address, so it is not suitable for real patients.
RESEND_API_KEY=
#
# DEMO MODE — if NEITHER SMTP_HOST nor RESEND_API_KEY is set, patient verification links are
# returned in the /api/register response and logged to the backend console so accounts can still
# be activated. This never happens once a provider is configured.
#
# Staff MFA: with a working email provider you can enable staff email OTP. Leave EMPTY in
# production to require MFA for all staff roles, or set a value (e.g. "disabled") to turn it off.
# WARNING: an empty value + no working provider = staff cannot complete login.
MFA_REQUIRED_ROLES=disabled

# --- Staff onboarding domain allowlist ---
# Comma-separated workplace domains allowed for staff (Doctor/Nurse/Pharmacist/Admin)
# account creation. Generic inboxes (gmail, etc.) are rejected. Defaults to mediflow.com.
STAFF_EMAIL_DOMAINS=mediflow.com

# --- Anti-automation (Cloudflare Turnstile) ---
# Server-side verification of the login / registration / triage challenge. When
# TURNSTILE_SECRET is EMPTY, verification is skipped (safe for local/dev/CI); set it to
# enforce in production. Create a free widget at
# https://dash.cloudflare.com/?to=/:account/turnstile , then:
#   TURNSTILE_SECRET        = the widget's SECRET key (backend runtime; keep out of git)
#   VITE_TURNSTILE_SITEKEY  = the widget's SITE key. This is baked into the frontend at BUILD
#     time (docker build-arg, see docker-compose.prod.yml), NOT read at runtime — it is public.
TURNSTILE_SECRET=
VITE_TURNSTILE_SITEKEY=

# --- Authenticator-app TOTP (privileged accounts) ---
# Admin/Doctor accounts can self-enroll an authenticator app (Google Authenticator, Authy,
# 1Password, etc.) from their dashboard for a phishing-resistant step-up factor. No external
# service or email is needed — codes are computed offline (RFC 6238). TOTP_ISSUER is just the
# label shown next to the account inside the app; it defaults to "MediFlow" if unset.
TOTP_ISSUER=MediFlow
