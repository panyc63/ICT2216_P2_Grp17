# Backend API base URL (optional; defaults to http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Idle auto-logout limit in milliseconds (optional; defaults to 900000 = 15 min).
# Set a small value to test the timeout quickly, e.g. 15000 for 15 seconds.
# VITE_IDLE_LIMIT_MS=15000

# Firebase Web SDK config (used for WebRTC signaling over Realtime Database).
# Copy these from Firebase console -> Project settings -> your Web app.
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
